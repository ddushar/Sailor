# Скопируй в .env и подставь свои значения (ID — только цифры; несколько ID — через запятую).
# second_bot.py читает через python-dotenv.

# --- Токен и сервер (обязательно) ---
SECOND_BOT_TOKEN=
# или один токен на оба варианта:
# DISCORD_TOKEN=

SECOND_BOT_GUILD_ID=
# или:
# GUILD_ID=

# --- Заявки / модерация ---
# Заявки только в два канала (третий общий не используется).
APPLICATIONS_RP_CHANNEL_ID=
APPLICATIONS_VZP_CHANNEL_ID=
# ID ролей при «Принять» в канале обзвона (0 = не выдавать для этого типа).
APPLICATION_RP_ACCEPT_ROLE_ID=
APPLICATION_VZP_ACCEPT_ROLE_ID=
MOD_ROLE_ID=
# Главный список ролей «модерации». У всех фич ниже пустой *_ROLE_IDS = те же роли, что здесь.
MODERATION_ROLE_IDS=
ADMIN_ROLE_IDS=
# Логи в канал: выход, кик, бан, роли, ник, голос (эмбед «📋 Лог»). 0 = выкл.
# Нужны права: просмотр журнала аудита. ID текстового канала.
MOD_ACTION_LOG_CHANNEL_ID=
# Только «вход на сервер» — в этот канал (0 = не задано: вход пишется в MOD_ACTION_LOG_CHANNEL_ID).
MEMBER_JOIN_LOG_CHANNEL_ID=

# --- Панель /panel и /karta_terry ---
# Пусто = MODERATION_ROLE_IDS; иначе только эти роли (+ владелец / manage_guild).
PANEL_ROLE_IDS=
PANEL_CHANNEL_IDS=
# Имя файла в папке с second_bot.py (или полный путь). Лимит Discord ~25 МБ на вложение.
PANEL_IMAGE_FILE=panel.gif

# --- Сборы /sbor: канал обязателен (если задан); роли пусто = MODERATION_ROLE_IDS ---
VZP_GATHER_ROLE_IDS=
VZP_GATHER_CHANNEL_ID=
VZH_GATHER_ROLE_IDS=
VZH_GATHER_CHANNEL_ID=
POSTAVKA_GATHER_ROLE_IDS=
POSTAVKA_GATHER_CHANNEL_ID=
MP_GATHER_ROLE_IDS=
MP_GATHER_CHANNEL_ID=

# Пинг в посте + ЛС при /sbor (одна роль на тип — ID роли)
VZP_GATHER_PING_ROLE_ID=
VZH_GATHER_PING_ROLE_ID=
POSTAVKA_GATHER_PING_ROLE_ID=
MP_GATHER_PING_ROLE_ID=

# --- Тег роли в канале → рассылка в ЛС (см. комментарий в second_bot.py) ---
# Категории (ID через запятую): пинг в любом канале/теме внутри категории. Можно без CHANNEL_IDS.
ROLE_MENTION_DM_CATEGORY_IDS=
# Опционально: только эти каналы (ID темы форума не сюда — родитель уже в категории).
ROLE_MENTION_DM_CHANNEL_IDS=
ROLE_MENTION_DM_TARGET_ROLE_IDS=
# Пусто = любой может писать в этих каналах; иначе только эти роли (+ владелец / manage_guild):
ROLE_MENTION_DM_ALLOWED_ROLE_IDS=

# --- Карта терры /karta_terry ---
TERRA_MAP_IMAGE_DIR=foto
# Баннер сверху плашки (gif, png, webm…). Пусто = тот же файл, что PANEL_IMAGE_FILE (обычно panel.gif).
TERRA_MAP_BANNER_FILE=
# Формат: подпись:файл | подпись:файл1+файл2
TERRA_MAP_OPTIONS=
TERRA_MAP_CHANNEL_IDS=

# --- Таймер атаки/дефа /timer_ata_def ---
WAR_TIMER_CHANNEL_IDS=
# Пусто = MODERATION_ROLE_IDS
WAR_TIMER_ROLE_IDS=
WAR_TIMER_PING_ROLE_ID=
# Сдвиг по кнопкам (часы; можно 1,5). Если обе строки пусты — общий WAR_TIMER_BUMP_HOURS.
WAR_TIMER_ATTACK_BUMP_HOURS=3
WAR_TIMER_DEFENSE_BUMP_HOURS=1.5
# WAR_TIMER_BUMP_HOURS=4

# --- /stats_panel: «Добавить каптик» (+) и форма ---
STATS_CHANNEL_IDS=
# Пусто = MODERATION_ROLE_IDS
STATS_ROLE_IDS=
STATS_PING_ROLE_ID=

# --- /autopark: панель машин, бронь, ЛС при взятии и освобождении ---
# Пусто = MODERATION_ROLE_IDS
AUTOPARK_ROLE_IDS=
# Только эти каналы; пусто = любой текстовый / ветка.
AUTOPARK_CHANNEL_IDS=
# User ID (не роли), кому можно «Изменить список» дополнительно к ролям ниже.
AUTOPARK_EDIT_USER_IDS=
# Пусто = MODERATION_ROLE_IDS; иначе только эти роли (+ user ID выше).
AUTOPARK_EDIT_ROLE_IDS=
# Длительность брони в минутах (по умолчанию 60).
AUTOPARK_BOOKING_MINUTES=60
# Стартовый список, пока нет файла: `КЛЮЧ:подпись|...` или просто подпись (ключ сгенерируется).
AUTOPARK_DEFAULT_CARS=PESTONA01:Pestona — PESTONA01
# JSON со списком машин по серверам (рядом со скриптом, если не абсолютный путь).
AUTOPARK_LIST_FILE=autopark_cars.json

# --- /sbormoney: пост с фото и суммой — только в перечисленных каналах (обязательно, иначе команда отключена) ---
SBORMONEY_CHANNEL_IDS=
# Пусто = MODERATION_ROLE_IDS
SBORMONEY_POST_ROLE_IDS=
# Лимит вложения в МБ (1–25, по умолчанию 10).
SBORMONEY_MAX_ATTACHMENT_MB=10
# --- /podarok: розыгрыш (пустой PODAROK_POST_ROLE_IDS = MODERATION_ROLE_IDS) ---
# PODAROK_POST_ROLE_IDS=
# В посте пинг ролей с доступом к каналу розыгрыша (несколько ID через запятую). Пусто = @everyone.
# PODAROK_CHANNEL_ACCESS_ROLE_IDS=
# ЛС о новом розыгрыше: если задан PODAROK_CHANNEL_ACCESS_ROLE_IDS выше — всем с этими ролями; иначе одна роль (0 = без ЛС).
# PODAROK_PING_ROLE_ID=
# JSON: розыгрыш (/podarok) и денежный сбор (/sbormoney) — участники, победители, «собрано». Рядом со скриптом, если не абсолютный путь.
# PODAROK_SBORMONEY_STATE_FILE=podarok_sbormoney_state.json
# JSON: таймер att/deff, журнал статистики ВЗП (/stats_panel), сборы /sbor, контракты /kontrakt, приём заявок РП/VZP.
# PANEL_EXTRA_STATE_FILE=panel_extra_state.json

# --- Контракты /kontrakt ---
KONTRAKT_CHANNEL_ID=
# Пусто = MODERATION_ROLE_IDS
KONTRAKT_POST_ROLE_IDS=
# Пикнул/Отказ: пусто = MODERATION_ROLE_IDS
KONTRAKT_MANAGER_ROLE_IDS=
KONTRAKT_RULES_TEXT=
KONTRAKT_NEW_CONTRACT_PING_ROLE_IDS=

# --- Пост с @роль → удалить предыдущий пост бота → снова пост (по кругу). Канал или роль 0 = выкл. ---
DAILY_ROLE_PING_CHANNEL_ID=1489950736606560426
DAILY_ROLE_PING_ROLE_ID=1482140063591825428
# Ежедневно в указанные моменты (ЧЧ:ММ, несколько через запятую). Если пусто — режим интервала ниже.
# Пример: 09:00,21:30
DAILY_ROLE_PING_TIMES= 12
# Часовой пояс для DAILY_ROLE_PING_TIMES (IANA), по умолчанию Москва
DAILY_ROLE_PING_TIMEZONE=Europe/Moscow
# Если DAILY_ROLE_PING_TIMES пуст: через сколько часов удалить и отправить следующее (по умолчанию 23)
DAILY_ROLE_PING_INTERVAL_HOURS=11
# Текст под пингом (пусто = «Напоминание.»)
DAILY_ROLE_PING_MESSAGE=

# --- Отчёты (как «Добавить статистику»): /mpitog и /vzhitog, кнопка +, сразу пост в канал ---
# ID каналов через запятую. Пусто = без ограничения (не рекомендуется).
MATERIAL_REPORT_CHANNEL_IDS=
ACTIVITY_REPORT_CHANNEL_IDS=
# Кто может вызвать команды и жать +. Пусто = MODERATION_ROLE_IDS
MATERIAL_REPORT_PANEL_ROLE_IDS=
ACTIVITY_REPORT_PANEL_ROLE_IDS=

# --- Временные голосовые: зайти в хаб → свой войс; панель в Text-in-Voice этого канала. 0 = выкл. ---
TEMP_VC_HUB_CHANNEL_ID=
# Категория для новых войсов (0 = та же, что у хаба)
TEMP_VC_CATEGORY_ID=